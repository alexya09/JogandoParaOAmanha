global.topicss[$"123"] = [
	//SPEAKER("Carmen",Sprite11, PORTRAIT_SIDE.PORTRAITLEFT),
	TEXT("Oi! Que bom te ver por aqui! Agora você vai aprender sobre um conceito muito importante na programação: as variáveis!"),
	
	TEXT("Para navegar pela aula, use a tecla E para avançar e a tecla Q para voltar. Quando estiver pronto, aperte E para começar!"),

	TEXT("Introdução às Variáveis na Programação\n\nVariáveis são elementos fundamentais na programação. Elas funcionam como caixinhas que armazenam dados que podem ser usados e modificados ao longo do código."),

	TEXT("Cada variável tem um NOME (para identificá-la) e um TIPO, que define o tipo de dado que ela pode guardar. Os principais tipos de dados são:\n- INT\n- FLOAT\n- BOOL\n- CHAR"),

	TEXT("INT (número inteiro):\nGuarda números inteiros, ou seja, números sem vírgula.\nExemplos: 1, 16, 45, -2\n\nExemplo visual: uma caixinha com o número 45 escrito nela:\n[Caixa] -> 45"),

	TEXT("FLOAT (número com vírgula ou ponto):\nGuarda números decimais, com vírgula ou ponto.\nExemplos: 3.14, 0.5, -7.25\n\nExemplo visual:\n[Caixa] -> 3.14"),

	TEXT("BOOL (booleano):\nGuarda apenas duas opções: true (verdadeiro) ou false (falso).\nÉ como um botão de LIGA/DESLIGA.\nExemplos: true, false\n\nExemplos visuais:\n[Caixa] -> true\n[Caixa] -> false"),

	TEXT("CHAR (caractere):\nGuarda apenas um único caractere, como uma letra, número ou símbolo.\nSempre usamos aspas simples para definir um char.\nExemplos: 'A', 'z', '!'\n\nExemplo visual:\n[Caixa] -> 'A'"),

	TEXT("Resumo:\n- INT: 10, -3, 42\n- FLOAT: 3.14, 0.1\n- BOOL: true, false\n- CHAR: 'B', '?'"),

	TEXT("Usar o tipo certo de variável é como escolher a caixinha perfeita para guardar o que você precisa no seu programa."),

	TEXT("Agora é sua vez de praticar!\nOrganize as caixinhas nos portais corretos de acordo com o tipo de variável."),
	
	TEXT("Lembre-se dos controles:\n- Use SPACE para empurrar a caixinha\n- Clique na alavanca azul para chamar a próxima caixa\n- Clique na alavanca roxa para resetar a posição da caixa"),

	TEXT("Divirta-se programando e boa sorte no desafio!")
];

